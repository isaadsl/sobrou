# Copie este arquivo para ".env" (sem o ".example") e preencha com os
# valores do seu projeto Supabase: Project Settings → API

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon-aqui

# URL pública do backend (pasta /backend) que serve o Assistente Financeiro.
# Em desenvolvimento local pode ficar vazia (o proxy do Vite cuida disso).
# Em produção, preencha com a URL onde você publicou o backend Express
# (ex: Render, Railway, Fly.io). Sem isso, o Assistente Financeiro fica
# indisponível no site publicado — o restante do app funciona normalmente.
VITE_API_URL=
